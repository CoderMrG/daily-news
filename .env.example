# Copy this file to .env and fill local values.
# Do not commit .env.

# Anthropic-compatible GLM/DashScope translation.
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/YOUR_APP_ID
ANTHROPIC_AUTH_TOKEN=your_api_key_here
DAILY_NEWS_TRANSLATION_PROVIDER=anthropic
DAILY_NEWS_ANTHROPIC_MODEL=glm-5.2
DAILY_NEWS_ANTHROPIC_DISABLE_THINKING=1

# Optional run controls.
# DAILY_NEWS_DATE=2026-06-26
# DAILY_NEWS_FROM_RAW=1
# DAILY_NEWS_INCLUDE_TWITTER=1

# Optional Obsidian sync.
# DAILY_NEWS_OBSIDIAN_VAULT_DIR=/path/to/YourVault
# DAILY_NEWS_OBSIDIAN_SUBDIR=Daily News
